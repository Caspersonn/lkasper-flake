{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/master/assets/oh-my-openagent.schema.json",

  // Model setup for this machine:
  //   anthropic/*  -> Claude Max 20x via opencode-with-claude proxy (flat-rate, high limits)
  //   openai/*     -> ChatGPT Codex subscription (flat-rate)
  //   opencode/*   -> free tier, last-resort safety only
  // Bedrock is intentionally NOT used.

  "agents": {
    // Main orchestrator. Claude flagship with max extended thinking.
    "sisyphus": {
      "model": "anthropic/claude-opus-4-8",
      "variant": "max",
      "fallback_models": ["openai/gpt-5.5", "opencode/big-pickle"]
    },

    // Strategic planner (interview-mode). Same flagship.
    "prometheus": {
      "model": "anthropic/claude-opus-4-8",
      "variant": "max",
      "fallback_models": ["openai/gpt-5.5"]
    },

    // Pre-planning / plan-review consultant.
    "metis": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": ["openai/gpt-5.5"]
    },

    // Todo-list orchestrator.
    "atlas": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": ["openai/gpt-5.5"]
    },

    // Deep autonomous worker. GPT-native — do NOT move to Claude.
    "hephaestus": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "medium",
      "fallback_models": ["openai/gpt-5.4"]
    },

    // Architecture / debugging consultant. GPT preferred, Opus backup.
    "oracle": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high",
      "fallback_models": ["anthropic/claude-opus-4-8"]
    },

    // High-accuracy plan/code reviewer.
    "momus": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "xhigh",
      "fallback_models": ["anthropic/claude-opus-4-8"]
    },

    // Fast codebase grep. Cheap/fast utility — do not upgrade.
    "explore": {
      "model": "openai/gpt-5.4-mini-fast",
      "fallback_models": ["anthropic/claude-haiku-4-5"]
    },

    // External docs / code search. Cheap/fast utility.
    "librarian": {
      "model": "openai/gpt-5.4-mini-fast",
      "fallback_models": ["anthropic/claude-haiku-4-5"]
    },

    // Vision / screenshots / PDF.
    "multimodal-looker": {
      "model": "openai/gpt-5.5",
      "fallback_models": ["anthropic/claude-sonnet-4-6"]
    }
  },

  "categories": {
    // Trivial single-file changes, typo fixes.
    "quick": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": ["anthropic/claude-haiku-4-5"]
    },

    // Autonomous problem-solving, thorough research.
    "deep": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "medium"
    },

    // Deep logical reasoning, complex architecture.
    "ultrabrain": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "xhigh",
      "fallback_models": ["anthropic/claude-opus-4-8"]
    },

    // General low-effort tasks.
    "unspecified-low": {
      "model": "anthropic/claude-sonnet-4-6"
    },

    // General high-effort tasks.
    "unspecified-high": {
      "model": "anthropic/claude-opus-4-8",
      "variant": "max"
    },

    // No Gemini/GLM available — Claude Opus handles frontend/UI well.
    "visual-engineering": {
      "model": "anthropic/claude-opus-4-8",
      "fallback_models": ["openai/gpt-5.5"]
    },

    // Creative / unconventional approaches.
    "artistry": {
      "model": "anthropic/claude-opus-4-8"
    },

    // Documentation, prose, technical writing.
    "writing": {
      "model": "anthropic/claude-sonnet-4-6"
    }
  },

  // Max 20x gives generous Claude headroom; allow more parallel anthropic work.
  // Keep openai (Codex sub) modest; free opencode tier can run wide.
  "background_task": {
    "providerConcurrency": {
      "anthropic": 6,
      "openai": 3,
      "opencode": 10
    }
  }
}
